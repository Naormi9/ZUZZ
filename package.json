{
  "name": "zuzz",
  "version": "0.1.0",
  "private": true,
  "description": "ZUZZ — המקום שבו עסקאות זזות באמת",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @zuzz/database db:generate",
    "db:push": "pnpm --filter @zuzz/database db:push",
    "db:seed": "pnpm --filter @zuzz/database db:seed",
    "db:studio": "pnpm --filter @zuzz/database db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.0.0"
  }
}
