# =============================================================================
# ZUZZ Production Environment Configuration
# Copy to .env.production and fill in real values
# =============================================================================

# Database (PostgreSQL with PostGIS)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/zuzz_prod?schema=public&sslmode=require"

# Redis
REDIS_URL="redis://:PASSWORD@HOST:6379"

# Auth — MUST be a secure random string, minimum 32 characters
AUTH_SECRET=""
AUTH_URL="https://zuzz.co.il"

# Object Storage (S3-compatible)
STORAGE_ENDPOINT="https://s3.amazonaws.com"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="zuzz-media-prod"
STORAGE_REGION="il-central-1"

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_FROM="noreply@zuzz.co.il"

# API
API_URL="https://api.zuzz.co.il"
API_PORT=4000

# Web URLs
NEXT_PUBLIC_API_URL="https://api.zuzz.co.il"
NEXT_PUBLIC_APP_URL="https://zuzz.co.il"
NEXT_PUBLIC_WS_URL="wss://api.zuzz.co.il"

# Admin
NEXT_PUBLIC_ADMIN_URL="https://admin.zuzz.co.il"

# Maps
MAPS_PROVIDER="google"
MAPS_API_KEY=""

# Payments
PAYMENT_PROVIDER="stripe"
PAYMENT_API_KEY=""

# Feature Flags
FEATURE_FLAGS_PROVIDER="local"

# Observability
LOG_LEVEL="info"
NODE_ENV="production"
SENTRY_DSN=""

# Security
RATE_LIMIT_ENABLED="true"
