# ============================================================================
# ZUZZ — Environment Variables
# Copy to .env and adjust values for your environment.
# Required variables for local dev are marked with [REQUIRED].
# ============================================================================

# ---------- Database [REQUIRED] ----------
DATABASE_URL="postgresql://zuzz:zuzz_dev@localhost:5432/zuzz_dev?schema=public"

# ---------- Redis [REQUIRED] ----------
REDIS_URL="redis://localhost:6379"

# ---------- Auth [REQUIRED] ----------
# Must be at least 32 characters. Do NOT use this default in production.
AUTH_SECRET="change-me-in-production-min-32-chars-long"
AUTH_URL="http://localhost:3000"

# ---------- Storage (MinIO / S3) ----------
# When set, uploads go to S3/MinIO via @zuzz/storage provider.
# When unset, falls back to local filesystem (uploads/ directory).
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="zuzz-media"
STORAGE_REGION="us-east-1"
# Optional: override the public URL for stored objects
# STORAGE_PUBLIC_URL="https://cdn.zuzz.co.il"

# ---------- Email ----------
# When SMTP_HOST is set, emails are sent via SMTP (MailHog in dev, real provider in prod).
# When SMTP_HOST is empty/unset, falls back to mock provider (logs to console).
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="noreply@zuzz.co.il"
# For production SMTP:
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="apikey"
# SMTP_PASS="your-sendgrid-api-key"

# ---------- API ----------
API_URL="http://localhost:4000"
API_PORT=4000

# ---------- Web ----------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# ---------- Admin ----------
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# ---------- Rate Limiting ----------
# Set to "true" to enable Redis-backed rate limiting (requires Redis).
# Recommended "true" for staging/production.
RATE_LIMIT_ENABLED="false"

# ---------- Maps (provider abstraction) ----------
MAPS_PROVIDER="mock"
MAPS_API_KEY=""

# ---------- Payments (provider abstraction) ----------
PAYMENT_PROVIDER="sandbox"
PAYMENT_API_KEY=""

# ---------- Feature Flags ----------
FEATURE_FLAGS_PROVIDER="local"

# ---------- Observability ----------
LOG_LEVEL="debug"
NODE_ENV="development"

# Sentry (optional, leave empty to disable)
SENTRY_DSN=""

# OpenTelemetry (optional, leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=""
