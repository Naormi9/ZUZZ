# =============================================================================
# ZUZZ Staging Environment Configuration
# Copy to .env.staging and fill in values
# =============================================================================

# Database
DATABASE_URL="postgresql://zuzz:PASSWORD@HOST:5432/zuzz_staging?schema=public"

# Redis
REDIS_URL="redis://:PASSWORD@HOST:6379"

# Auth
AUTH_SECRET=""
AUTH_URL="https://staging.zuzz.co.il"

# Object Storage (S3 / MinIO)
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="zuzz-media-staging"
STORAGE_REGION="us-east-1"

# Email
SMTP_HOST=""
SMTP_PORT="587"
SMTP_FROM="noreply@staging.zuzz.co.il"

# API
API_URL="https://api-staging.zuzz.co.il"
API_PORT=4000

# Web URLs
NEXT_PUBLIC_API_URL="https://api-staging.zuzz.co.il"
NEXT_PUBLIC_APP_URL="https://staging.zuzz.co.il"
NEXT_PUBLIC_WS_URL="wss://api-staging.zuzz.co.il"
NEXT_PUBLIC_SITE_URL="https://staging.zuzz.co.il"

# Admin
NEXT_PUBLIC_ADMIN_URL="https://admin-staging.zuzz.co.il"

# Maps — mock is rejected when NODE_ENV=production; use google or mapbox
MAPS_PROVIDER="google"
MAPS_API_KEY=""

# Payments — sandbox is rejected when NODE_ENV=production; use stripe or tranzilla
PAYMENT_PROVIDER="stripe"
PAYMENT_API_KEY=""

# Feature Flags
FEATURE_FLAGS_PROVIDER="local"

# Observability
LOG_LEVEL="debug"
NODE_ENV="production"
SENTRY_DSN=""

# Security
RATE_LIMIT_ENABLED="true"
